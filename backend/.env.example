# Project
COMPOSE_PROJECT_NAME=obhod-backend

# Traefik
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080

# PostgreSQL
POSTGRES_USER=obhod
POSTGRES_PASSWORD=obhod
POSTGRES_DB=obhod
POSTGRES_PORT=5432
DATABASE_URL=postgresql://obhod:obhod@postgres:5432/obhod

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=obhod-media

# Redpanda
REDPANDA_IMAGE=redpandadata/redpanda:v24.3.6
REDPANDA_EXTERNAL_PORT=19092
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Auth
AUTH_SERVICE_NAME=auth-service
DEV_AUTH_TOKEN=dev-token
DEV_ADMIN_TOKEN=dev-admin-token

# Field service
FIELD_SERVICE_NAME=field-service

# Report service
REPORT_SERVICE_NAME=report-service
